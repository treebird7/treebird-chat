# Default registry — used by `pnpm publish:npm`
registry=https://registry.npmjs.org/

# GitHub Packages — used for @treebird7-scoped publishes.
# Token is injected at publish time via GITHUB_TOKEN env var.
@treebird7:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
