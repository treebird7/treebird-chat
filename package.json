{
  "name": "treebird-chat",
  "version": "0.3.7",
  "description": "Terminal chat CLI for humans and AI agents — shared markdown file, zero server, real-time",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/treebird7/treebird-chat"
  },
  "keywords": [
    "chat",
    "cli",
    "ai",
    "agents",
    "markdown",
    "tui",
    "multi-agent"
  ],
  "homepage": "https://github.com/treebird7/treebird-chat#readme",
  "bin": {
    "corrwait": "bin/corrwait.mjs",
    "treebird-chat": "bin/treebird-chat.mjs",
    "trbc": "bin/treebird-chat.mjs",
    "trbcw": "bin/treebird-chat-wizard.mjs",
    "treebird-chat-tail": "bin/treebird-chat-tail.mjs",
    "treebird-chat-allow": "bin/treebird-chat-allow.mjs",
    "treebird-chat-deny": "bin/treebird-chat-deny.mjs",
    "treebird-chat-bridge": "bin/treebird-chat-bridge.mjs",
    "treebird-chat-join": "bin/treebird-chat-join.mjs",
    "treebird-chat-watch": "bin/treebird-chat-watch.mjs",
    "treebird-chat-session": "bin/treebird-chat-session.mjs",
    "treebird-chat-init": "bin/treebird-chat-init.mjs",
    "treebird-chat-add-bridge": "bin/treebird-chat-add-bridge.mjs",
    "treebird-chat-invite": "bin/treebird-chat-invite.mjs",
    "gemma-bridge": "bin/gemma-bridge.mjs",
    "treebird-chat-wizard": "bin/treebird-chat-wizard.mjs",
    "treebird-chat-status": "bin/treebird-chat-status.mjs"
  },
  "files": [
    "bin/corrwait.mjs",
    "bin/gemma-bridge.mjs",
    "bin/treebird-chat.mjs",
    "bin/treebird-chat-add-bridge.mjs",
    "bin/treebird-chat-allow.mjs",
    "bin/treebird-chat-bridge.mjs",
    "bin/treebird-chat-deny.mjs",
    "bin/treebird-chat-init.mjs",
    "bin/treebird-chat-invite.mjs",
    "bin/treebird-chat-join.mjs",
    "bin/treebird-chat-session.mjs",
    "bin/treebird-chat-status.mjs",
    "bin/treebird-chat-tail.mjs",
    "bin/treebird-chat-watch.mjs",
    "bin/treebird-chat-wizard.mjs",
    "lib/",
    "scripts/",
    "templates/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "prepublishOnly": "npm test",
    "publish:npm": "pnpm publish --access public --no-git-checks",
    "publish:github": "node scripts/publish-github.mjs",
    "publish:all": "pnpm run publish:npm && pnpm run publish:github"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "dotenv": "^17.4.2"
  },
  "author": "Treebird",
  "license": "MIT"
}
